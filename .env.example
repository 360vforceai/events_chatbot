# Discord (Developer Portal -> Bot -> Token; right-click server -> Copy Server ID)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# OpenAI
OPENAI_API_KEY=

# Supabase (Project Settings -> API)
SUPABASE_URL=
SUPABASE_KEY=

# Admin (any random string for scraper API routes)
ADMIN_API_KEY=

# Scraper
SCRAPE_INTERVAL_HOURS=6

# Web (Next.js — use web/.env.local, not bot/.env)
NEXT_PUBLIC_API_URL=http://localhost:8000

